# ============================================
# AGENTI — Variables de entorno
# Copiar a .env.local y rellenar con valores reales
# ============================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Meta / WhatsApp ---
WHATSAPP_APP_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_GRAPH_API_VERSION=v21.0
WHATSAPP_GRAPH_API_BASE=https://graph.facebook.com/v21.0

# --- LLM Principal (Gemini Flash 2.5) ---
LLM_PRIMARY_PROVIDER=gemini
LLM_PRIMARY_MODEL=gemini-2.5-flash
LLM_PRIMARY_API_KEY=
LLM_PRIMARY_MAX_TOKENS=600
LLM_PRIMARY_TEMPERATURE=0.3

# --- LLM Fast/Cheap (Qwen via Together.ai) ---
LLM_FAST_PROVIDER=together
LLM_FAST_MODEL=Qwen/Qwen2.5-72B-Instruct-Turbo
LLM_FAST_API_KEY=
LLM_FAST_MAX_TOKENS=200
LLM_FAST_TEMPERATURE=0.1

# --- Email (Resend) ---
RESEND_API_KEY=

# --- Encriptación ---
APP_ENCRYPTION_KEY=
